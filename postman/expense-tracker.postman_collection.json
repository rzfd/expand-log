            "body": {
              "mode": "raw",
              "raw": "{\"category_id\":{{categoryId}},\"year\":{{year}},\"month\":{{month}},\"amount\":\"{{updatedBudgetAmount}}\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/budgets/{{budgetId}}"
          }
        },
        {
          "name": "Delete Budget",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/budgets/{{budgetId}}"
          }
        }
      ]
    },
    {

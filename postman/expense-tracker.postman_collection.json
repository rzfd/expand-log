            "body": {
              "mode": "raw",
              "raw": "{\"category_id\":{{categoryId}},\"type\":\"expense\",\"amount\":\"{{recurringAmount}}\",\"note\":\"{{recurringNote}}\",\"frequency\":\"{{recurringFrequency}}\",\"start_date\":\"{{recurringStartDate}}\",\"end_date\":\"{{recurringEndDate}}\",\"active\":true}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/recurring-transactions",
            "description": "Creates a recurring transaction and stores the returned `id` in `recurringTransactionId`."
          }
        },
        {
          "name": "Update Recurring Transaction",

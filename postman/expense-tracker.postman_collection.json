{
  "info": {
    "_postman_id": "d63a5c57-fd70-4dd2-8eb0-0f20ca6d88b7",
    "name": "Expense Tracker API",
    "description": "Ready-to-import Postman collection for the local Expense Tracker API. Recommended order: Register, Login, Create Category, then run the remaining create/list requests. Login stores the JWT in `accessToken`, and the create requests store returned IDs in collection variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "System",
      "item": [
        {
          "name": "Root",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/"
          }
        },
        {
          "name": "Healthz",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/healthz"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('email', 'user+' + Date.now() + '@example.com');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"{{email}}\",\"password\":\"{{password}}\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/auth/register",
            "description": "Creates a new user. This request generates a unique `email` collection variable before sending."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json && json.data && json.data.access_token) {",
                  "    pm.collectionVariables.set('accessToken', json.data.access_token);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"{{email}}\",\"password\":\"{{password}}\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/auth/login",
            "description": "Authenticates the current `email` and stores `data.access_token` in the `accessToken` collection variable."
          }
        }
      ]
    },
    {
      "name": "Categories",
      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{accessToken}}",
            "type": "string"
          }
        ]
      },
      "item": [
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/categories"
          }
        },
        {
          "name": "Create Category",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json && json.data && json.data.id) {",
                  "    pm.collectionVariables.set('categoryId', String(json.data.id));",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"{{categoryName}}\",\"type\":\"expense\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/categories",
            "description": "Creates an expense category and stores the returned `id` in `categoryId`."
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"{{updatedCategoryName}}\",\"type\":\"expense\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/categories/{{categoryId}}"
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/categories/{{categoryId}}"
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{accessToken}}",
            "type": "string"
          }
        ]
      },
      "item": [
        {
          "name": "List Transactions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/transactions?start_date={{filterStartDate}}&end_date={{filterEndDate}}&type=expense&category_id={{categoryId}}&min_amount={{minAmount}}&max_amount={{maxAmount}}&page={{page}}&page_size={{pageSize}}"
          }
        },
        {
          "name": "Get Transaction By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/transactions/{{transactionId}}"
          }
        },
        {
          "name": "Create Transaction",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json && json.data && json.data.id) {",
                  "    pm.collectionVariables.set('transactionId', String(json.data.id));",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"category_id\":{{categoryId}},\"type\":\"expense\",\"amount\":\"{{transactionAmount}}\",\"note\":\"{{transactionNote}}\",\"transaction_date\":\"{{transactionDate}}\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/transactions",
            "description": "Creates a transaction and stores the returned `id` in `transactionId`."
          }
        },
        {
          "name": "Update Transaction",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"category_id\":{{categoryId}},\"type\":\"expense\",\"amount\":\"{{updatedTransactionAmount}}\",\"note\":\"{{updatedTransactionNote}}\",\"transaction_date\":\"{{transactionDate}}\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/transactions/{{transactionId}}"
          }
        },
        {
          "name": "Delete Transaction",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/transactions/{{transactionId}}"
          }
        }
      ]
    },

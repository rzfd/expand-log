                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"category_id\":{{categoryId}},\"type\":\"expense\",\"amount\":\"{{updatedRecurringAmount}}\",\"note\":\"{{updatedRecurringNote}}\",\"frequency\":\"{{recurringFrequency}}\",\"start_date\":\"{{recurringStartDate}}\",\"end_date\":\"{{recurringEndDate}}\",\"active\":true}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/recurring-transactions/{{recurringTransactionId}}"
          }
        },
        {
          "name": "Delete Recurring Transaction",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/recurring-transactions/{{recurringTransactionId}}"
          }
        }
      ]
    }
